# Pi Surveying Backend — Environment Variables
# Copy to .env and fill in values
# NODE_ENV values: local | development | staging | production | test
NODE_ENV="development"

# Deployment environment (set by ECS task definition in AWS)
# Values: dev | staging | production — leave unset for local development
# DCS_ENV=

DATABASE_URL="postgresql://user:password@localhost:5432/pi_surveying"
REDIS_URL="redis://localhost:6379"

JWT_SECRET="change-me-in-production-min-32-chars"
JWT_EXPIRY="7d"
REFRESH_TOKEN_EXPIRY="30d"

AWS_S3_BUCKET="pi-surveying-documents"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"

SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL="noreply@pisurveying.com"
SENDGRID_FROM_NAME="Pi Surveying"
SENDGRID_MAGIC_LINK_TEMPLATE_ID=""
SENDGRID_OTP_TEMPLATE_ID=""

CUSTOMERIO_SITE_ID=""
CUSTOMERIO_API_KEY=""
CUSTOMERIO_REGION="US"

QUICKBOOKS_CLIENT_ID=""
QUICKBOOKS_CLIENT_SECRET=""
QUICKBOOKS_REALM_ID=""
QUICKBOOKS_ENVIRONMENT="sandbox"

GOOGLE_MAPS_API_KEY=""

# Frontend origin for CORS
FRONTEND_URL="http://localhost:3000"
# Mobile app scheme for CORS
MOBILE_SCHEME="pi-surveying"

# Server port (staging/production uses 3000 via SSM; locally use 4000 to avoid conflict with Next.js)
PORT=4000

# Staging trap — set STAGING_TRAP_EMAIL to redirect all outbound emails
# in non-production envs. Excluded emails (comma-separated) pass through unchanged.
STAGING_TRAP_EMAIL=""
STAGING_TRAP_EXCLUDED_EMAILS=""

# Sentry (optional)
SENTRY_DSN=""

# Admin notification recipients
HOLLY_EMAIL=""
RESEARCH_LEADER_EMAIL=""
ALEX_EMAIL=""

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:noreply@pisurveying.com"

# QuickBooks webhook signature verification (from QB developer dashboard)
QUICKBOOKS_WEBHOOK_VERIFIER_TOKEN=""