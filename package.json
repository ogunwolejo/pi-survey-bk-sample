{
  "name": "pi-surveying-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "start:worker": "node dist/worker.js",
    "start:migrate": "prisma migrate deploy && node dist/server.js",
    "start:entrypoint": "node dist/entrypoint.js",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:create": "prisma migrate dev --create-only",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:reset": "prisma migrate reset",
    "db:migrate:revert": "prisma db execute --stdin < ./prisma/revert.sql",
    "db:migrate:status": "prisma migrate status",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.996.0",
    "@aws-sdk/client-ssm": "^3.998.0",
    "@aws-sdk/s3-request-presigner": "^3.996.0",
    "@googlemaps/google-maps-services-js": "^3.4.2",
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^7.4.1",
    "@sendgrid/client": "^8.1.6",
    "@sendgrid/mail": "^8.1.6",
    "archiver": "^7.0.1",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.34.0",
    "cors": "^2.8.5",
    "customerio-node": "^4.0.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.0.0",
    "expo-server-sdk": "^6.0.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "pdf-lib": "^1.17.1",
    "pg": "^8.18.0",
    "prisma": "^7.4.1",
    "@prisma/client": "^7.4.1",
    "quickbooks-node-promise": "^3.3.14",
    "socket.io": "^4.8.1",
    "uuid": "^11.0.3",
    "web-push": "^3.6.7",
    "winston": "^3.19.0",
    "winston-console-format": "^1.0.8",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.16.0",
    "@types/uuid": "^10.0.0",
    "@types/web-push": "^3.6.4",
    "@vitest/coverage-v8": "2.1.9",
    "eslint": "^9.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.0.0",
    "vitest": "^2.1.8"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
