// Pi Surveying Portal — Prisma Schema
// Generated from specs/001-surveying-portal-mvp/data-model.md
// Database: PostgreSQL 15+

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

