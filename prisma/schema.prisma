model Quote {
  id                     String       @id @default(uuid())
  quoteNumber             String       @unique @map("quote_number")
  status                 QuoteStatus  @default(new) @map("status")
  clientId               String       @map("client_id")
  billingClientId        String?      @map("billing_client_id")
  propertyAddressLine1    String       @map("property_address_line_1")
  propertyAddressLine2    String?      @map("property_address_line_2")
  propertyCity           String       @map("property_city")
  propertyState          String       @map("property_state")
  propertyZip            String       @map("property_zip")
  propertyCounty         County?      @map("property_county")
  pin                    String       @map("pin")
  additionalPins         String[]     @map("additional_pins")
  surveyType             SurveyType?  @map("survey_type")
  propertyType           PropertyType? @map("property_type")
  closingDate            DateTime?    @db.Date @map("closing_date")
  onsiteContactFirstName String?      @map("onsite_contact_first_name")
  onsiteContactLastName  String?      @map("onsite_contact_last_name")
  onsiteContactPhone     String?      @map("onsite_contact_phone")
  lockedGates            LockedGates? @map("locked_gates")
  deliveryPreference     DeliveryPreference? @map("delivery_preference")
  legalDescription       String?      @map("legal_description")
  price                  Decimal?     @map("price")
  basePriceAtCreation    Decimal      @map("base_price_at_creation")
  priceOverrideReason    String?      @map("price_override_reason")
  estimatedTimeframe     String?      @map("estimated_timeframe")
  paymentTerms           PaymentTerms? @map("payment_terms")
  expiryDate             DateTime     @db.Date @map("expiry_date")
  source                 QuoteSource  @map("source")
  priority               Priority     @default(normal) @map("priority")
  assignedTo             String?      @map("assigned_to")
  internalNotes          String?      @map("internal_notes")
  referralSource         String?      @map("referral_source")
  customerType           QuoteCustomerType? @map("customer_type")
  billingAddressSameAsService Boolean @default(true) @map("billing_address_same_as_service")
  billingAddressLine1    String?      @map("billing_address_line_1")
  billingAddressLine2    String?      @map("billing_address_line_2")
  billingCity            String?      @map("billing_city")
  billingState           String?      @map("billing_state")
  billingZip             String?      @map("billing_zip")
  team                   Team         @default(residential) @map("team")

  // ── Property Research ────────────────────────────────────────────────────────
  lotSizeAcres             Decimal?           @db.Decimal(10, 4) @map("lot_size_acres")
  lotShape                 LotShape?          @map("lot_shape")
  drivewayType             DrivewayType?      @map("driveway_type")
  waterFeatures            WaterFeatures?     @map("water_features")
  vegetationDensity        VegetationDensity? @map("vegetation_density")
  subdivisionStatus        SubdivisionStatus? @map("subdivision_status")
  structuresOnProperty     String[]           @map("structures_on_property")
  structuresOther          String?            @map("structures_other")
  accessIssues             String?            @map("access_issues")

  // ── Rush Fee ─────────────────────────────────────────────────────────────────
  rushFeeApplied           Boolean            @default(false) @map("rush_fee_applied")
  rushFeeAmount            Decimal?           @db.Decimal(10, 2) @map("rush_fee_amount")
  rushFeeWaived            Boolean            @default(false) @map("rush_fee_waived")
  rushFeeWaivedReason      String?            @map("rush_fee_waived_reason")

  // ── ALTA / Complex ────────────────────────────────────────────────────────────
  altaTableASelections     Json?              @map("alta_table_a_selections")
  preferenceFormSentAt     DateTime?          @map("preference_form_sent_at")
  preferenceFormReceivedAt DateTime?          @map("preference_form_received_at")

  // ── Price Breakdown ────────────────────────────────────────────────────────────
  priceBreakdown           Json?              @map("price_breakdown")

  // ── Pin Location (survey point marker) ────────────────────────────────────────
  pinLatitude              Decimal?           @db.Decimal(10, 7) @map("pin_latitude")
  pinLongitude             Decimal?           @db.Decimal(10, 7) @map("pin_longitude")

  // ── Form Resume ───────────────────────────────────────────────────────────────
  lastCompletedStep        Int?               @map("last_completed_step")

  createdBy              String?      @map("created_by")
  createdAt              DateTime     @default(now()) @map("created_at")
  updatedBy              String?      @map("updated_by")
  updatedAt              DateTime     @updatedAt @map("updated_at")
  deletedAt              DateTime?    @map("deleted_at")
  deletedBy              String?      @map("deleted_by")

  client                 Client       @relation("QuoteClient", fields: [clientId], references: [id])
  billingClient          Client?      @relation("QuoteBillingClient", fields: [billingClientId], references: [id])
  assignedToUser         User?        @relation("QuoteAssignedTo", fields: [assignedTo], references: [id])
  createdByUser          User?        @relation("QuoteCreatedBy", fields: [createdBy], references: [id])
  updatedByUser          User?        @relation("QuoteUpdatedBy", fields: [updatedBy], references: [id])
  deletedByUser          User?        @relation("QuoteDeletedBy", fields: [deletedBy], references: [id])

  paymentRequired        Boolean?       @map("payment_required")
  paymentRequiredReason  String?        @map("payment_required_reason")

  quoteTokens            QuoteToken[]
  contractSignatures     ContractSignature[]
  abandonedForms         AbandonedForm[]
  order                  Order?
  invoice                Invoice?
  payments               Payment[]
  activityEntries        QuoteActivityEntry[]

  @@index([clientId])
  @@index([status])
  @@index([assignedTo])
  @@index([team, status])
  @@index([propertyCounty])
  @@index([customerType])
  @@map("quotes")
}

model QuoteToken {
  id        String         @id @default(uuid())
  token     String         @unique @map("token")
  quoteId   String         @map("quote_id")
  tokenType QuoteTokenType @default(legacy) @map("token_type")
  expiresAt DateTime       @map("expires_at")
  usedAt    DateTime?      @map("used_at")
  createdAt DateTime       @default(now()) @map("created_at")

  quote     Quote          @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@map("quote_tokens")
}

model ContractSignature {
  id             String    @id @default(uuid())
  quoteId        String    @map("quote_id")
  signerName     String    @map("signer_name")
  signerEmail    String    @map("signer_email")
  s3Key          String    @map("s3_key")
  signatureData  Json?     @map("signature_data")
  signedAt       DateTime  @map("signed_at")
  ipAddress      String?   @db.Inet @map("ip_address")
  createdAt      DateTime  @default(now()) @map("created_at")

  quote          Quote     @relation(fields: [quoteId], references: [id])

  @@map("contract_signatures")
}

model OrderToken {
  id        String         @id @default(uuid())
  token     String         @unique @map("token")
  orderId   String         @map("order_id")
  tokenType OrderTokenType @default(proposal) @map("token_type")
  expiresAt DateTime       @map("expires_at")
  usedAt    DateTime?      @map("used_at")
  createdAt DateTime       @default(now()) @map("created_at")

  order     Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_tokens")
}

model OrderContractSignature {
  id             String    @id @default(uuid())
  orderId        String    @map("order_id")
  signerName     String    @map("signer_name")
  signerEmail    String    @map("signer_email")
  s3Key          String    @map("s3_key")
  signatureData  Json?     @map("signature_data")
  signedAt       DateTime  @map("signed_at")
  ipAddress      String?   @db.Inet @map("ip_address")
  createdAt      DateTime  @default(now()) @map("created_at")

  order          Order     @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@map("order_contract_signatures")
}

model AbandonedForm {
  id          String    @id @default(uuid())
  formType    FormType  @map("form_type")
  email       String    @map("email")
  partialData Json      @map("partial_data")
  quoteId     String?   @map("quote_id")
  abandonedAt DateTime  @map("abandoned_at")
  recoveredAt DateTime? @map("recovered_at")
  createdAt   DateTime @default(now()) @map("created_at")

  quote       Quote?    @relation(fields: [quoteId], references: [id])

  @@map("abandoned_forms")
}

model Order {
  id                      String       @id @default(uuid())
  orderNumber             String       @unique @map("order_number")
  quoteId                 String?      @unique @map("quote_id")
  clientId                String?      @map("client_id")
  billingClientId         String?      @map("billing_client_id")
  status                  OrderStatus  @default(draft) @map("status")
  orderType               OrderType    @default(standard) @map("order_type")
  propertyAddressLine1    String?      @map("property_address_line_1")
  propertyAddressLine2    String?      @map("property_address_line_2")
  propertyCity            String?      @map("property_city")
  propertyState           String?      @map("property_state")
  propertyZip             String?      @map("property_zip")
  propertyCounty          County?      @map("property_county")
  pin                     String?      @map("pin")
  additionalPins          String[]     @map("additional_pins")
  propertyType            PropertyType? @map("property_type")
  surveyType              SurveyType?  @map("survey_type")
  price                   Decimal?     @map("price")
  paymentTerms            PaymentTerms? @map("payment_terms")
  closingDate             DateTime?    @db.Date @map("closing_date")
  requestedDate           DateTime?    @db.Date @map("requested_date")
  onsiteContactFirstName  String?      @map("onsite_contact_first_name")
  onsiteContactLastName   String?      @map("onsite_contact_last_name")
  onsiteContactPhone     String?      @map("onsite_contact_phone")
  lockedGates             LockedGates? @map("locked_gates")
  deliveryPreference      DeliveryPreference? @map("delivery_preference")
  legalDescription       String?      @map("legal_description")
  titleCommitmentS3Key   String?      @map("title_commitment_s3_key")
  dropDeadDate           DateTime?    @db.Date @map("drop_dead_date")
  internalClosingDate    DateTime?    @db.Date @map("internal_closing_date")
  dueDate                DateTime?    @db.Date @map("due_date")
  isRush                 Boolean      @default(false) @map("is_rush")
  rushFeeAmount          Decimal?     @db.Decimal(10, 2) @map("rush_fee_amount")
  rushFeeWaived         Boolean      @default(false) @map("rush_fee_waived")
  rushFeeWaivedReason    String?      @map("rush_fee_waived_reason")
  source                 OrderSource? @map("source")
  priority               Priority     @default(normal) @map("priority")
  team                   Team?        @map("team")
  suppressClientEmails   Boolean      @default(false) @map("suppress_client_emails")
  internalNotes          String?      @map("internal_notes")
  referralSource         String?      @map("referral_source")

  // ── Property Research (mirrors Quote) ──────────────────────────────────────
  lotSizeAcres             Decimal?           @db.Decimal(10, 4) @map("lot_size_acres")
  lotShape                 LotShape?          @map("lot_shape")
  drivewayType             DrivewayType?      @map("driveway_type")
  waterFeatures            WaterFeatures?     @map("water_features")
  vegetationDensity        VegetationDensity? @map("vegetation_density")
  subdivisionStatus        SubdivisionStatus? @map("subdivision_status")
  structuresOnProperty     String[]           @default([]) @map("structures_on_property")
  structuresOther          String?            @map("structures_other")
  accessIssues             String?            @map("access_issues")

  // ── Pricing (standalone orders without a quote) ───────────────────────────
  basePriceAtCreation      Decimal?           @map("base_price_at_creation")
  priceBreakdown           Json?              @map("price_breakdown")
  priceOverrideReason      String?            @map("price_override_reason")

  // ── Pin Location (survey point marker) ────────────────────────────────────────
  pinLatitude              Decimal?           @db.Decimal(10, 7) @map("pin_latitude")
  pinLongitude             Decimal?           @db.Decimal(10, 7) @map("pin_longitude")

  // ── Public Form Contact (stored on draft before Client record exists) ──────
  firstName              String?      @map("first_name")
  lastName               String?      @map("last_name")
  email                  String?      @map("email")
  phone                  String?      @map("phone")
  company                String?      @map("company")
  customerType           QuoteCustomerType? @map("customer_type")

  // ── Progressive Save ───────────────────────────────────────────────────────
  lastCompletedStep      Int          @default(0) @map("last_completed_step")

  // ── Payment Requirement (resolved when sending standalone order to client) ─
  paymentRequired            Boolean? @map("payment_required")
  paymentRequiredReason      String?  @map("payment_required_reason")

  // ── Denormalized Payment Tracking (updated atomically with payment writes) ─
  amountPaid                 Decimal  @default(0) @db.Decimal(10, 2) @map("amount_paid")
  balanceRemaining           Decimal  @default(0) @db.Decimal(10, 2) @map("balance_remaining")

  // ── Billing Address ────────────────────────────────────────────────────────
  billingAddressSameAsService Boolean @default(true) @map("billing_address_same_as_service")
  billingAddressLine1    String?      @map("billing_address_line_1")
  billingAddressLine2    String?      @map("billing_address_line_2")
  billingCity            String?      @map("billing_city")
  billingState           String?      @map("billing_state")
  billingZip             String?      @map("billing_zip")

  createdBy              String?      @map("created_by")
  createdAt              DateTime     @default(now()) @map("created_at")
  updatedBy              String?      @map("updated_by")
  updatedAt              DateTime     @updatedAt @map("updated_at")
  deletedAt              DateTime?    @map("deleted_at")
  deletedBy              String?      @map("deleted_by")

  quote                  Quote?       @relation(fields: [quoteId], references: [id])
  client                 Client?      @relation("OrderClient", fields: [clientId], references: [id])
  billingClient          Client?      @relation("OrderBillingClient", fields: [billingClientId], references: [id])
  createdByUser          User?       @relation("OrderCreatedBy", fields: [createdBy], references: [id])
  updatedByUser          User?       @relation("OrderUpdatedBy", fields: [updatedBy], references: [id])
  deletedByUser          User?       @relation("OrderDeletedBy", fields: [deletedBy], references: [id])

  jobs                   Job[]
  invoices               Invoice[]
  payments               Payment[]
  shippingTasks          ShippingTask[]
  documentMetadata       DocumentMetadata[]
  deliveryChecklist      DeliveryChecklist?
  deliveryTracking       DeliveryTracking?
  activityEntries        OrderActivityEntry[]
  orderTokens            OrderToken[]
  orderContractSignatures OrderContractSignature[]
  researchFields         OrderResearchField[]

  @@index([clientId])
  @@index([quoteId])
  @@index([status])
  @@index([team, status])
  @@index([dueDate])
  @@map("orders")
}

model Job {
  id              String    @id @default(uuid())
  jobNumber       String    @unique @map("job_number")
  orderId         String    @map("order_id")
  status          JobStatus @default(unassigned) @map("status")
  assignedCrewId  String?   @map("assigned_crew_id")
  fieldDate       DateTime? @db.Date @map("field_date")
  stakingRequired Boolean   @default(false) @map("staking_required")
  team            Team      @map("team")

  // Field Ops Pipeline fields
  internalDueDate       DateTime?        @db.Date @map("internal_due_date")
  propertyLat           Decimal?         @db.Decimal(10, 7) @map("property_lat")
  propertyLng           Decimal?         @db.Decimal(10, 7) @map("property_lng")
  propertyAddressLine1  String?          @map("property_address_line_1")
  propertyAddressLine2  String?          @map("property_address_line_2")
  propertyCity          String?          @map("property_city")
  propertyState         String?          @map("property_state")
  propertyZip           String?          @map("property_zip")
  propertyCounty        County?          @map("property_county")
  pin                   String?          @map("pin")
  additionalPins        String[]         @default([]) @map("additional_pins")
  claimedById           String?          @map("claimed_by_id")
  claimedAt             DateTime?        @map("claimed_at")
  plsReviewRoundTrips   Int              @default(0) @map("pls_review_round_trips")
  isAlta                Boolean          @default(false) @map("is_alta")
  complexityTag         String?          @map("complexity_tag")
  specialNotes          String?          @map("special_notes")
  lastStatusChangedAt   DateTime?        @map("last_status_changed_at")
  lastStatusChangedById String?          @map("last_status_changed_by_id")

  createdBy       String?   @map("created_by")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedBy       String?   @map("updated_by")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")
  deletedBy       String?   @map("deleted_by")

  order                Order     @relation(fields: [orderId], references: [id])
  assignedCrew         Crew?     @relation(fields: [assignedCrewId], references: [id])
  claimedBy            User?     @relation("JobClaimedBy", fields: [claimedById], references: [id])
  lastStatusChangedBy  User?     @relation("JobLastStatusChangedBy", fields: [lastStatusChangedById], references: [id])
  createdByUser        User?     @relation("JobCreatedBy", fields: [createdBy], references: [id])
  updatedByUser        User?     @relation("JobUpdatedBy", fields: [updatedBy], references: [id])
  deletedByUser        User?     @relation("JobDeletedBy", fields: [deletedBy], references: [id])

  activityFeed         ActivityFeed[]
  stakingRequests      StakingRequest[]
  shippingTasks        ShippingTask[]
  documentMetadata     DocumentMetadata[]
  deliveryChecklist    DeliveryChecklist?
  deliveryTracking     DeliveryTracking?
  chatMessages         JobChatMessage[]
  issueFlags           JobIssueFlag[]
  plsSignOffs          PLSSignOff[]
  routeJobs            RouteJob[]
  payments             Payment[]

  @@index([orderId])
  @@index([assignedCrewId])
  @@index([fieldDate])
  @@index([assignedCrewId, fieldDate])
  @@index([status, team])
  @@index([internalDueDate])
  @@index([claimedById])
  @@map("jobs")
}

model Invoice {
  id                    String        @id @default(uuid())
  invoiceNumber         String        @unique @map("invoice_number")
  orderId               String?       @map("order_id")
  quoteId               String?       @unique @map("quote_id")
  clientId              String        @map("client_id")
  status                InvoiceStatus @default(draft) @map("status")
  invoiceDate           DateTime      @db.Date @map("invoice_date")
  dueDate               DateTime      @db.Date @map("due_date")
  subtotal              Decimal       @map("subtotal")
  taxRate               Decimal       @map("tax_rate")
  taxAmount             Decimal       @map("tax_amount")
  discountAmount        Decimal       @map("discount_amount")
  creditApplied         Decimal       @map("credit_applied")
  totalAmount           Decimal       @map("total_amount")
  amountPaid            Decimal       @map("amount_paid")
  balanceDue            Decimal       @map("balance_due")
  taxExempt             Boolean       @default(false) @map("tax_exempt")
  taxExemptCertificate  String?       @map("tax_exempt_certificate")
  notes                 String?       @map("notes")
  quickbooksInvoiceId   String?       @map("quickbooks_invoice_id")
  syncStatus            SyncStatus    @default(pending) @map("sync_status")
  createdBy             String?       @map("created_by")
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedBy             String?       @map("updated_by")
  updatedAt             DateTime      @updatedAt @map("updated_at")

  order                 Order?        @relation(fields: [orderId], references: [id])
  quote                 Quote?        @relation(fields: [quoteId], references: [id])
  client                Client        @relation(fields: [clientId], references: [id])
  createdByUser         User?         @relation("InvoiceCreatedBy", fields: [createdBy], references: [id])
  updatedByUser         User?         @relation("InvoiceUpdatedBy", fields: [updatedBy], references: [id])

  invoiceLineItems      InvoiceLineItem[]
  payments              Payment[]
  credits               Credit[]

  @@index([orderId])
  @@index([clientId])
  @@index([status])
  @@index([syncStatus])
  @@map("invoices")
}

model InvoiceLineItem {
  id          String  @id @default(uuid())
  invoiceId   String  @map("invoice_id")
  description String  @map("description")
  quantity    Int     @default(1) @map("quantity")
  unitPrice   Decimal @map("unit_price")
  amount      Decimal @map("amount")
  sortOrder   Int     @map("sort_order")

  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_line_items")
}

model Payment {
  id                    String         @id @default(uuid())
  paymentNumber         String         @unique @map("payment_number")
  invoiceId             String?        @map("invoice_id")
  quoteId               String?        @map("quote_id")
  orderId               String?        @map("order_id")
  jobId                 String?        @map("job_id")
  status                PaymentStatus  @default(completed) @map("status")
  paymentDate           DateTime       @map("payment_date")
  amount                Decimal        @map("amount")
  baseAmount            Decimal?       @map("base_amount")
  taxAmount             Decimal?       @map("tax_amount")
  processingFee         Decimal?       @map("processing_fee")
  convenienceFee        Decimal?       @map("convenience_fee")
  creditCardFee         Decimal?       @map("credit_card_fee")
  paymentMethod         PaymentMethod  @map("payment_method")
  cardBrand             String?        @map("card_brand")
  cardLastFour          String?        @map("card_last_four")
  checkNumber           String?        @map("check_number")
  bankName              String?        @map("bank_name")
  transactionId         String?        @map("transaction_id")
  quickbooksPaymentId   String?        @unique @map("quickbooks_payment_id")
  paymentSource         PaymentSource  @map("payment_source")
  paymentType           PaymentType?   @map("payment_type")
  recordedBy            String?        @map("recorded_by")
  notes                 String?        @map("notes")
  createdAt             DateTime       @default(now()) @map("created_at")
  completedAt           DateTime?      @map("completed_at")
  failedAt              DateTime?      @map("failed_at")
  failureReason         String?        @map("failure_reason")

  invoice         Invoice?       @relation(fields: [invoiceId], references: [id])
  quote           Quote?         @relation(fields: [quoteId], references: [id])
  order           Order?         @relation(fields: [orderId], references: [id])
  job             Job?           @relation(fields: [jobId], references: [id])
  recordedByUser  User?          @relation(fields: [recordedBy], references: [id])

  @@index([orderId])
  @@index([jobId])
  @@index([status])
  @@index([paymentDate(sort: Desc)])
  @@index([paymentNumber])
  @@map("payments")
}

model Credit {
  id          String    @id @default(uuid())
  clientId    String    @map("client_id")
  invoiceId   String?   @map("invoice_id")
  amount      Decimal   @map("amount")
  reason      String    @map("reason")
