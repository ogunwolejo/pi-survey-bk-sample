model ClientPortalSession {
  id           String     @id @default(uuid())
  clientId     String     @map("client_id")
  sessionToken String     @unique @map("session_token")
  authMethod   AuthMethod @map("auth_method")
  expiresAt    DateTime   @map("expires_at")
  createdAt    DateTime   @default(now()) @map("created_at")

  client       Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("client_portal_sessions")
}

model MagicLinkRequest {
  id        String    @id @default(uuid())
  email     String    @map("email")
  token     String    @unique @map("token")
  clientId  String?   @map("client_id")
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  client    Client?   @relation(fields: [clientId], references: [id])

  @@map("magic_link_requests")
}

model StakingRequest {
  id           String               @id @default(uuid())
  jobId        String               @map("job_id")
  requestedBy  String               @map("requested_by")
  status       StakingRequestStatus @default(pending) @map("status")
  requestedAt  DateTime             @map("requested_at")
  respondedAt  DateTime?            @map("responded_at")
  respondedBy  String?              @map("responded_by")
  timeoutAt    DateTime             @map("timeout_at")
  notes        String?              @map("notes")
  escalatedAt  DateTime?            @map("escalated_at")

  job         Job                @relation(fields: [jobId], references: [id])
  requestedByUser User            @relation("StakingRequestRequestedBy", fields: [requestedBy], references: [id])
  respondedByUser User?          @relation("StakingRequestRespondedBy", fields: [respondedBy], references: [id])

  @@map("staking_requests")
}

model DocumentMetadata {
  id            String        @id @default(uuid())
  jobId         String?       @map("job_id")
  orderId       String?       @map("order_id")
  documentType  String        @map("document_type")
  filename      String        @map("filename")
  displayName   String?       @map("display_name")
  s3Key         String        @map("s3_key")
  fileSize      BigInt        @map("file_size")
  versionNumber Int           @default(1) @map("version_number")
  uploadedBy    String?       @map("uploaded_by")
  uploadedAt    DateTime      @map("uploaded_at")
  createdAt     DateTime      @default(now()) @map("created_at")

  // Field Ops Pipeline fields
  mimeType      String?       @map("mime_type")
  fileCategory  FileCategory? @map("file_category")
  chatMessageId String?       @map("chat_message_id")

  // Research document classification
  researchDocType ResearchDocumentType? @map("research_doc_type")

  job           Job?          @relation(fields: [jobId], references: [id])
  order         Order?        @relation(fields: [orderId], references: [id])
  uploadedByUser User?        @relation(fields: [uploadedBy], references: [id])
  chatMessage   JobChatMessage? @relation(fields: [chatMessageId], references: [id])

  @@map("document_metadata")
}

model OrderResearchField {
  id         String   @id @default(uuid())
  orderId    String   @map("order_id")
  fieldName  String   @map("field_name")
  fieldValue String   @map("field_value")
  createdBy  String?  @map("created_by")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  order         Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdByUser User?  @relation("ResearchFieldCreatedBy", fields: [createdBy], references: [id])

  @@unique([orderId, fieldName])
  @@index([orderId])
  @@map("order_research_fields")
}

// =============================================================================
// Field Ops Pipeline Models
// =============================================================================

model Route {
  id                    String      @id @default(uuid())
  routeDate             DateTime    @db.Date @map("route_date")
  crewId                String      @map("crew_id")
  status                RouteStatus @default(draft) @map("status")
  totalDriveTimeMinutes Int?        @map("total_drive_time_minutes")
  totalDistanceMeters   Int?        @map("total_distance_meters")
  directionsPolyline    String?     @map("directions_polyline")
  publishedAt           DateTime?   @map("published_at")
  publishedById         String?     @map("published_by_id")
  cancelledAt           DateTime?   @map("cancelled_at")
  cancelReason          String?     @map("cancel_reason")
  notificationJobId     String?     @map("notification_job_id")
  createdBy             String?     @map("created_by")
  createdAt             DateTime    @default(now()) @map("created_at")
  updatedAt             DateTime    @updatedAt @map("updated_at")

  crew                  Crew        @relation(fields: [crewId], references: [id])
  publishedBy           User?       @relation("RoutePublishedBy", fields: [publishedById], references: [id])
  createdByUser         User?       @relation("RouteCreatedBy", fields: [createdBy], references: [id])
  routeJobs             RouteJob[]

  @@unique([crewId, routeDate])
  @@index([routeDate])
  @@index([status])
  @@map("routes")
}

model RouteJob {
  id                        String    @id @default(uuid())
  routeId                   String    @map("route_id")
  jobId                     String    @map("job_id")
  sortOrder                 Int       @map("sort_order")
  estimatedArrival          DateTime? @map("estimated_arrival")
  estimatedDurationMinutes  Int?      @map("estimated_duration_minutes")
  legDriveTimeMinutes       Int?      @map("leg_drive_time_minutes")
  legDistanceMeters         Int?      @map("leg_distance_meters")
  siteAccessEmailJobId      String?   @map("site_access_email_job_id")
  siteContactName           String?   @map("site_contact_name")
  siteContactEmail          String?   @map("site_contact_email")
  siteContactPhone          String?   @map("site_contact_phone")

  route                     Route     @relation(fields: [routeId], references: [id], onDelete: Cascade)
  job                       Job       @relation(fields: [jobId], references: [id])

  @@unique([routeId, sortOrder])
  @@index([jobId])
  @@map("route_jobs")
}

model JobChatMessage {
  id               String    @id @default(uuid())
  jobId            String    @map("job_id")
  authorId         String?   @map("author_id")
  content          String    @map("content")
  mentionedUserIds String[]  @map("mentioned_user_ids")
  isSystemEvent    Boolean   @default(false) @map("is_system_event")
  metadata         Json?     @map("metadata")
  createdAt        DateTime  @default(now()) @map("created_at")
  editedAt         DateTime? @map("edited_at")
  deletedAt        DateTime? @map("deleted_at")

  job              Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  author           User?     @relation("JobChatMessageAuthor", fields: [authorId], references: [id])
  attachments      DocumentMetadata[]

  @@index([jobId, createdAt(sort: Desc)])
  @@index([authorId])
  @@map("job_chat_messages")
}

model JobIssueFlag {
  id             String            @id @default(uuid())
  jobId          String            @map("job_id")
  category       IssueFlagCategory @map("category")
  severity       IssueFlagSeverity @map("severity")
  description    String            @map("description")
  status         IssueFlagStatus   @default(open) @map("status")
  raisedById     String            @map("raised_by_id")
  raisedAt       DateTime          @default(now()) @map("raised_at")
  resolvedById   String?           @map("resolved_by_id")
  resolvedAt     DateTime?         @map("resolved_at")
  resolutionNote String?           @map("resolution_note")

  job            Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  raisedBy       User              @relation("IssueFlagRaisedBy", fields: [raisedById], references: [id])
  resolvedBy     User?             @relation("IssueFlagResolvedBy", fields: [resolvedById], references: [id])

  @@index([jobId, status])
  @@map("job_issue_flags")
}

model PLSSignOff {
  id          String    @id @default(uuid())
  jobId       String    @map("job_id")
  plsUserId   String    @map("pls_user_id")
  approvedAt  DateTime  @default(now()) @map("approved_at")
  notes       String?   @map("notes")

  job         Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  plsUser     User      @relation("PLSSignOffUser", fields: [plsUserId], references: [id])

  @@index([jobId])
  @@map("pls_sign_offs")
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  endpoint  String   @map("endpoint")
  p256dh    String   @map("p256dh")
  auth      String   @map("auth")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, endpoint])
  @@index([userId])
  @@map("push_subscriptions")
}

model ExpoPushToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @map("token")
  deviceId  String?  @map("device_id")
  platform  String?  @map("platform")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, token])
  @@index([userId])
  @@map("expo_push_tokens")
}

model ChatMessage {
  id               String         @id @default(uuid())
  entityType       ChatEntityType @map("entity_type")
  entityId         String         @map("entity_id")
  authorId         String?        @map("author_id")
  content          String         @map("content") @db.VarChar(5000)
  mentionedUserIds String[]       @map("mentioned_user_ids")
  isSystemEvent    Boolean        @default(false) @map("is_system_event")
  eventType        String?        @map("event_type")
  metadata         Json?          @map("metadata")
  createdAt        DateTime       @default(now()) @map("created_at")
  editedAt         DateTime?      @map("edited_at")
  deletedAt        DateTime?      @map("deleted_at")

  author           User?          @relation("ChatMessageAuthor", fields: [authorId], references: [id])

  @@index([entityType, entityId, createdAt(sort: Desc)])
  @@index([authorId])
  @@map("chat_messages")
}

model QuickBooksToken {
  id                      String   @id @default(uuid())
  realmId                 String   @unique @map("realm_id")
  accessToken             String   @map("access_token")
  refreshToken            String   @map("refresh_token")
  accessTokenExpiresAt    DateTime @map("access_token_expires_at")
  refreshTokenExpiresAt   DateTime @map("refresh_token_expires_at")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  @@map("quickbooks_tokens")
}
