// -----------------------------------------------------------------------------
// User (Better Auth + staff fields)
// Merged: Better Auth base (id, email, name, emailVerified, image) + staff fields
// Configure Better Auth with: user: { modelName: "users", fields: { emailVerified: "email_verified" } }
// -----------------------------------------------------------------------------
model User {
  id                     String           @id @default(uuid())
  name                   String           @map("name")
  email                  String           @unique @map("email")
  emailVerified          Boolean          @default(false) @map("email_verified")
  image                  String?          @map("image")
  createdAt              DateTime         @default(now()) @map("created_at")
  updatedAt              DateTime         @updatedAt @map("updated_at")

  // Staff fields (internal portal users)
  role                   UserRole         @map("role")
  platformAccess         PlatformAccess   @map("platform_access")
  team                   UserTeam         @default(residential) @map("team")
  isActive               Boolean          @default(true) @map("is_active")
  notificationPreferences Json?           @map("notification_preferences")
  crewId                 String?          @map("crew_id")

  crew                   Crew?            @relation(fields: [crewId], references: [id])
  sessions               Session[]
  accounts               Account[]

  quotesAssignedTo       Quote[]          @relation("QuoteAssignedTo")
  quotesCreatedBy        Quote[]          @relation("QuoteCreatedBy")
  quotesUpdatedBy        Quote[]          @relation("QuoteUpdatedBy")
  quotesDeletedBy        Quote[]          @relation("QuoteDeletedBy")
  ordersCreatedBy        Order[]          @relation("OrderCreatedBy")
  ordersUpdatedBy        Order[]          @relation("OrderUpdatedBy")
  ordersDeletedBy        Order[]          @relation("OrderDeletedBy")
  jobsCreatedBy          Job[]            @relation("JobCreatedBy")
  jobsUpdatedBy          Job[]            @relation("JobUpdatedBy")
  jobsDeletedBy          Job[]            @relation("JobDeletedBy")
  invoicesCreatedBy      Invoice[]        @relation("InvoiceCreatedBy")
  invoicesUpdatedBy      Invoice[]        @relation("InvoiceUpdatedBy")
  paymentsRecordedBy     Payment[]
  creditsApprovedBy      Credit[]
  clientsCreatedBy       Client[]         @relation("ClientCreatedBy")
  clientsUpdatedBy       Client[]         @relation("ClientUpdatedBy")
  clientsDeletedBy       Client[]        @relation("ClientDeletedBy")
  invitationsCreatedBy   Invitation[]
  shippingTasksShippedBy  ShippingTask[]
  deliveryChecklistsCompletedBy DeliveryChecklist[]
  deliveryChecklistItemsConfirmedBy DeliveryChecklistItem[]
  systemSettingsUpdatedBy SystemSetting[]
  entityAuditLogs        EntityAuditLog[]
  activityFeed           ActivityFeed[]
  quoteActivityEntries   QuoteActivityEntry[]
  orderActivityEntries   OrderActivityEntry[]
  notifications          Notification[]
  pushSubscriptions      PushSubscription[]
  expoPushTokens         ExpoPushToken[]
  stakingRequestsRequestedBy StakingRequest[] @relation("StakingRequestRequestedBy")
  stakingRequestsRespondedBy StakingRequest[] @relation("StakingRequestRespondedBy")
  documentMetadataUploadedBy DocumentMetadata[]

  // Field Ops Pipeline relations
  jobsClaimedBy          Job[]            @relation("JobClaimedBy")
  jobsLastStatusChanged  Job[]            @relation("JobLastStatusChangedBy")
  chatMessages           JobChatMessage[] @relation("JobChatMessageAuthor")
  unifiedChatMessages    ChatMessage[]    @relation("ChatMessageAuthor")
  issueFlagsRaised       JobIssueFlag[]   @relation("IssueFlagRaisedBy")
  issueFlagsResolved     JobIssueFlag[]   @relation("IssueFlagResolvedBy")
  plsSignOffs            PLSSignOff[]     @relation("PLSSignOffUser")
  routesPublished        Route[]          @relation("RoutePublishedBy")
  routesCreated          Route[]          @relation("RouteCreatedBy")

  // Research relations
  researchFieldsCreated  OrderResearchField[] @relation("ResearchFieldCreatedBy")

  // Payment audit relations
  paymentAuditLogs       PaymentAuditLog[]

  @@index([crewId])
  @@map("users")
}

// -----------------------------------------------------------------------------
// Better Auth: Session, Account, Verification
// -----------------------------------------------------------------------------
model Session {
  id        String   @id @default(uuid())
  expiresAt DateTime @map("expires_at")
  token     String   @unique @map("token")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  userId    String   @map("user_id")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(uuid())
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  userId                String    @map("user_id")
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?   @map("scope")
  password              String?   @map("password")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String    @id @default(uuid())
  identifier String    @map("identifier")
  value      String    @map("value")
  expiresAt  DateTime  @map("expires_at")
  createdAt  DateTime? @default(now()) @map("created_at")
  updatedAt  DateTime? @updatedAt @map("updated_at")

  @@map("verification")
}

model Invitation {
